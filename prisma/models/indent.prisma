enum IndentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Indent {
  id              String       @id @default(uuid())
  indentNumber    String       @map("indent_number")
  companyId       String       @map("company_id")
  createdByUserId String       @map("created_by_user_id")
  status          IndentStatus @default(DRAFT)
  remarks         String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id])
  createdBy      User            @relation("IndentCreatedBy", fields: [createdByUserId], references: [id])
  items          IndentItem[]
  materialIssues MaterialIssue[]

  @@unique([companyId, indentNumber])
  @@map("indents")
}

model IndentItem {
  id       String  @id @default(uuid())
  indentId String  @map("indent_id")
  itemId   String  @map("item_id")
  quantity Decimal @db.Decimal(12, 2)
  remarks  String?

  indent Indent @relation(fields: [indentId], references: [id], onDelete: Cascade)
  item   Item   @relation(fields: [itemId], references: [id])

  @@map("indent_items")
}
