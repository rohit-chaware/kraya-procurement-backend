enum RfqStatus {
  DRAFT
  SENT
  CLOSED
}

model Rfq {
  id              String    @id @default(uuid())
  rfqNumber       String    @map("rfq_number")
  companyId       String    @map("company_id")
  createdByUserId String    @map("created_by_user_id")
  status          RfqStatus @default(DRAFT)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company   Company       @relation(fields: [companyId], references: [id])
  createdBy User          @relation("RfqCreatedBy", fields: [createdByUserId], references: [id])
  items     RfqItem[]
  vendors   RfqVendor[]
  quotes    VendorQuote[]

  @@unique([companyId, rfqNumber])
  @@map("rfqs")
}

model RfqItem {
  id       String  @id @default(uuid())
  rfqId    String  @map("rfq_id")
  itemId   String  @map("item_id")
  quantity Decimal @db.Decimal(12, 2)

  rfq              Rfq               @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  item             Item              @relation(fields: [itemId], references: [id])
  vendorQuoteItems VendorQuoteItem[]

  @@map("rfq_items")
}

model RfqVendor {
  id       String @id @default(uuid())
  rfqId    String @map("rfq_id")
  vendorId String @map("vendor_id")

  rfq    Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@map("rfq_vendors")
}

model VendorQuote {
  id        String   @id @default(uuid())
  rfqId     String   @map("rfq_id")
  vendorId  String   @map("vendor_id")
  createdAt DateTime @default(now()) @map("created_at")

  rfq    Rfq               @relation(fields: [rfqId], references: [id])
  vendor Vendor            @relation(fields: [vendorId], references: [id])
  items  VendorQuoteItem[]

  @@unique([rfqId, vendorId])
  @@map("vendor_quotes")
}

model VendorQuoteItem {
  id          String  @id @default(uuid())
  quoteId     String  @map("quote_id")
  rfqItemId   String  @map("rfq_item_id")
  itemId      String  @map("item_id")
  quantity    Decimal @db.Decimal(12, 2)
  perUnitRate Decimal @map("per_unit_rate") @db.Decimal(12, 2)

  quote   VendorQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqItem RfqItem     @relation(fields: [rfqItemId], references: [id])

  @@map("vendor_quote_items")
}
