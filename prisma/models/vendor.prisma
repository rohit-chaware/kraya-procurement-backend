model Vendor {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  companyName String?  @map("company_name")
  password    String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rfqVendors RfqVendor[]
  quotes     VendorQuote[]

  @@map("vendors")
}
