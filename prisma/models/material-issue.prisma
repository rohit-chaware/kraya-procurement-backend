enum MiStatus {
  DRAFT
  ISSUED
}

model MaterialIssue {
  id             String   @id @default(uuid())
  miNumber       String   @map("mi_number")
  indentId       String?  @map("indent_id")
  issuedByUserId String   @map("issued_by_user_id")
  status         MiStatus @default(DRAFT)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  indent   Indent?  @relation(fields: [indentId], references: [id])
  issuedBy User     @relation("MiIssuedBy", fields: [issuedByUserId], references: [id])
  items    MiItem[]

  @@map("material_issues")
}

model MiItem {
  id       String  @id @default(uuid())
  miId     String  @map("mi_id")
  itemId   String  @map("item_id")
  quantity Decimal @db.Decimal(12, 2)

  materialIssue MaterialIssue @relation(fields: [miId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])

  @@map("mi_items")
}
